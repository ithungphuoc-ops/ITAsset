rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Ảnh thiết bị: đọc công khai (trang quét QR /device/[qr] không yêu cầu đăng
    // nhập), chỉ người đã đăng nhập mới upload được. Việc kiểm tra chi tiết role
    // (admin/it_staff) đã được thực hiện ở tầng Route Handler trước khi cấp
    // quyền ghi; rule ở đây là lớp phòng vệ thứ hai, chặn upload nặc danh.
    match /devices/{deviceId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
